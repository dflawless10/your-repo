  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.12.0"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.12.0"
    },
    "production": {
      "node": "22.12.0",
      "cache": {
        "disabled": false,
        "clear": true
      },
      "env": {
        "ORG_GRADLE_PROJECT_react.includeJitpackRepository": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
