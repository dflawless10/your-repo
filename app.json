{
  "expo": {
    "name": "BidGoatMobile",
    "slug": "BidGoatMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bidgoatmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "dflawless",
    "extra": {
      "API_URL": "http://10.0.0.170:5000",
      "EXPO_DEV_SERVER": "http://10.0.0.170:8081",
      "router": {},
      "eas": {
        "projectId": "7dd6cddd-4332-43aa-a42b-d3ed26434f39"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-audio",
      "expo-secure-store",
      "expo-video",
      "expo-web-browser",
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.bidgoat",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
